body {
    font-family: Arial;
    margin: 0;
}

header {
    background: #333;
    color: white;
    padding: 15px;
    text-align: center;
}

nav a {
    color: white;
    margin: 10px;
    text-decoration: none;
}

.hero {
    text-align: center;
    padding: 20px;
}

.menu-item {
    display: inline-block;
    margin: 20px;
}

footer {
    background: #222;
    color: white;
    text-align: center;
    padding: 10px;
}
